# 複製本檔為 infra/.env 後填入真正的金鑰；infra/.env 已被 gitignore，不會進版控。
# docker compose 會自動讀取同目錄的 .env。

# ---- 必填：真正的 OpenAI 金鑰（由 LiteLLM 保管，App 端只用虛擬金鑰 sk-1234）----
OPENAI_API_KEY=sk-請填入你的OpenAI金鑰

# ---- 以下皆為選填：docker-compose.yml 已內建開發用預設值，正式環境再覆寫 ----
# Langfuse 專案金鑰（LiteLLM 上報觀測用）
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-1234567890
# LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-1234567890
# Langfuse 後台登入帳密
# LANGFUSE_INIT_USER_EMAIL=admin@example.com
# LANGFUSE_INIT_USER_PASSWORD=password123
